# ============================================
# GENERAL APP SETTINGS
# ============================================
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=True

# ============================================
# DATABASE (MAIN APP DATABASE)
# ============================================
# Use SQLite or Postgres for development, I put both just in case
DATABASE_URL=sqlite:///./app.db

# If using PostgreSQL do the one below
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_comparator

# ============================================
# AI ASSISTANT API KEYS
# ============================================

# ChatGPT (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Grok
GROK_API_KEY=your_grok_api_key_here

# Copilot (manual mode should be fine)
COPILOT_MODE=manual   # options: manual / api (if ever supported)

# ============================================
# BENCHMARK DATABASES (FOR TASKS f & g)
# ============================================

# MySQL (Task f)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=test_db

# MongoDB (Task g)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=test_db
MONGO_COLLECTION=test_collection

# ============================================
# SECURITY / STATIC ANALYSIS TOOLS
# ============================================

# Semgrep
SEMGREP_ENABLED=True
SEMGREP_CONFIG=auto

# Bandit (Python security scanner)
BANDIT_ENABLED=True

# Coverity (only if we actually use it, so its optional)
COVERITY_ENABLED=False
COVERITY_PATH=/path/to/coverity/bin

# ============================================
# EXECUTION / SANDBOX SETTINGS
# ============================================

# Max execution time (seconds)
EXECUTION_TIMEOUT=10

# Limit memory usage (MB)
MAX_MEMORY_MB=256

# Allow network access during execution (should be False)
ALLOW_NETWORK=False

# ============================================
# FILE PATHS
# ============================================

# Workspace directory (generated files)
WORKSPACE_DIR=./workspace

# Reports directory
REPORTS_DIR=./reports/generated

# Benchmark tasks directory
BENCHMARKS_DIR=./benchmarks

# ============================================
# REPORT GENERATION
# ============================================

# Output formats
GENERATE_HTML_REPORT=True
GENERATE_PDF_REPORT=True

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log